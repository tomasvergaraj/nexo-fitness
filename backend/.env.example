APP_NAME=NexoFitness
APP_ENV=development
SECRET_KEY=change-me-in-production-use-a-long-random-string
DEBUG=true

DATABASE_URL=postgresql+asyncpg://nexo:nexo_password@localhost:5432/nexo_fitness
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

REDIS_URL=redis://localhost:6379/0

JWT_SECRET_KEY=change-me-jwt-secret-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=http://localhost:3000,http://localhost:5173

SENDGRID_API_KEY=
EMAIL_FROM=noreply@nexofitness.com
EMAIL_FROM_NAME=Nexo Fitness

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SAAS_MONTHLY_PRICE_ID=price_monthly_...
STRIPE_SAAS_QUARTERLY_PRICE_ID=price_quarterly_...
STRIPE_SAAS_SEMI_ANNUAL_PRICE_ID=price_semi_annual_...
STRIPE_SAAS_ANNUAL_PRICE_ID=price_annual_...
MERCADOPAGO_ACCESS_TOKEN=TEST-...
WEBPAY_ENVIRONMENT=integration
WEBPAY_COMMERCE_CODE=
WEBPAY_API_KEY=

# Fintoc (transferencias bancarias CLP)
# Obtén tus claves en https://app.fintoc.com/developers
FINTOC_SECRET_KEY=sk_test_...
FINTOC_WEBHOOK_SECRET=
FINTOC_RECIPIENT_HOLDER_ID=
FINTOC_RECIPIENT_ACCOUNT_NUMBER=
FINTOC_RECIPIENT_ACCOUNT_TYPE=checking_account
FINTOC_RECIPIENT_INSTITUTION_ID=
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:soporte@nexofitness.com

# Default frontend URL. If Fintoc builds fallback checkout return URLs from backend,
# use a public HTTPS URL here.
FRONTEND_URL=http://localhost:3000
SAAS_TRIAL_DAYS=14
SAAS_CURRENCY=CLP
SAAS_MONTHLY_PRICE=34990
SAAS_QUARTERLY_PRICE=94990
SAAS_SEMI_ANNUAL_PRICE=184990
SAAS_ANNUAL_PRICE=349900

AWS_S3_BUCKET=nexo-fitness-uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

RATE_LIMIT_PER_MINUTE=60

SUPERADMIN_EMAIL=admin@nexofitness.com
SUPERADMIN_PASSWORD=Admin123!

# Observability
SENTRY_DSN=
